# ─────────────────────────────────────────────────────────────
# MT5 Broker Credentials — copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────
MT5_LOGIN=YOUR_ACCOUNT_NUMBER
MT5_PASSWORD=YOUR_PASSWORD
MT5_SERVER=YourBroker-Demo

# ─────────────────────────────────────────────────────────────
# Trading Parameters
# ─────────────────────────────────────────────────────────────
SYMBOLS=EURUSD,GBPUSD
RISK_PCT=0.5
MAX_DAILY_LOSS_PCT=2.0
MAX_OB_AGE_BARS=100
MAX_OB_PER_SYMBOL=5
OB_STACK_TOLERANCE=1.5
DISPLACEMENT_THRESHOLD=1.0

# ─────────────────────────────────────────────────────────────
# Exit Configuration
# ─────────────────────────────────────────────────────────────
R_MULTIPLE_TP=2.4
BREAKEVEN_AT_R=0.8
MAX_HOLD_BARS=150
SL_SPREAD_BUFFER=1.4
TRAILING_STOP_ACTIVATION_R=1.3
TRAILING_STOP_DISTANCE_PIPS=21.0

# ─────────────────────────────────────────────────────────────
# Rev 3: ATR-Based SL/TP
# ─────────────────────────────────────────────────────────────
USE_ATR_SL=false
ATR_PERIOD=14
ATR_SL_MULTIPLIER=1.0

# ─────────────────────────────────────────────────────────────
# Rev 3: Partial Take Profit
# ─────────────────────────────────────────────────────────────
PARTIAL_TP_ENABLED=false
PARTIAL_TP_R=1.0
PARTIAL_TP_FRACTION=0.5

# ─────────────────────────────────────────────────────────────
# Rev 3: FVG Confluence Filter
# ─────────────────────────────────────────────────────────────
FVG_FILTER_ENABLED=true
FVG_REQUIRE_CONFLUENCE=false
FVG_QUALITY_THRESHOLD=0.0

# ─────────────────────────────────────────────────────────────
# Rev 3: Session Strength Filter
# ─────────────────────────────────────────────────────────────
SESSION_STRENGTH_MIN=0.0

# ─────────────────────────────────────────────────────────────
# Execution Quality Filters
# ─────────────────────────────────────────────────────────────
SPREAD_FILTER_MULTIPLIER=1.5
SIGNAL_LATENCY_BUDGET_S=1.5
NEWS_BLACKOUT_MINUTES=15

# ─────────────────────────────────────────────────────────────
# Rev 3: News Feed
# ─────────────────────────────────────────────────────────────
NEWS_CURRENCIES=USD,EUR,GBP
NEWS_CACHE_MAX_AGE_HOURS=12

# ─────────────────────────────────────────────────────────────
# Session Windows (UTC)
# ─────────────────────────────────────────────────────────────
SESSION_START_UTC=07:00
SESSION_END_UTC=16:30

# ─────────────────────────────────────────────────────────────
# Backtest / Validation
# ─────────────────────────────────────────────────────────────
SLIPPAGE_PIPS=0.5
WALK_FORWARD_SPLIT=0.7
MIN_PROFIT_FACTOR=1.2
