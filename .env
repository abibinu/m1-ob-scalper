# ─────────────────────────────────────────────────────────────
# MT5 Broker Credentials (NEVER commit real credentials)
# ─────────────────────────────────────────────────────────────
MT5_LOGIN=25674072
MT5_PASSWORD=R7Tp%plm
MT5_SERVER=VantageMarkets-Demo

# ─────────────────────────────────────────────────────────────
# Trading Parameters
# ─────────────────────────────────────────────────────────────
SYMBOLS=EURUSD,GBPUSD
RISK_PCT=0.5                 # Risk per trade: 0.25 or 0.5 (% of equity)
MAX_DAILY_LOSS_PCT=2.0       # Hard ceiling: shut down all pipelines
MAX_OB_AGE_BARS=145          # OB expires after N M1 bars (50-100)
MAX_OB_PER_SYMBOL=5          # Max concurrently tracked order blocks
OB_STACK_TOLERANCE=1.5       # Merge OBs within N * avg_spread
DISPLACEMENT_THRESHOLD=1.3   # Min candle range multiplier vs avg

# ─────────────────────────────────────────────────────────────
# Exit Configuration
# ─────────────────────────────────────────────────────────────
R_MULTIPLE_TP=3.0            # Take profit at N * R
BREAKEVEN_AT_R=0.7           # Move SL to breakeven at N * R (0 = disabled)
MAX_HOLD_BARS=65             # Time-based exit after N M1 bars
SL_SPREAD_BUFFER=1.7         # SL = OB far boundary + N * spread
TRAILING_STOP_ACTIVATION_R=0.0 # Start trailing when profit reaches N * R (0 = disabled)
TRAILING_STOP_DISTANCE_PIPS=0.0 # Distance to trail behind current price in pips

# ─────────────────────────────────────────────────────────────
# Execution Quality Filters
# ─────────────────────────────────────────────────────────────
SPREAD_FILTER_MULTIPLIER=1.5 # Skip entry if spread > N * 20-bar avg spread
SIGNAL_LATENCY_BUDGET_S=1.5  # Discard signal if latency > N seconds
NEWS_BLACKOUT_MINUTES=15     # No entries N minutes before/after news

# ─────────────────────────────────────────────────────────────
# Session Windows (UTC)
# ─────────────────────────────────────────────────────────────
SESSION_START_UTC=12:00      # NY open / London overlap start
SESSION_END_UTC=15:30        # London close / NY overlap end

# ─────────────────────────────────────────────────────────────
# Backtest / Validation
# ─────────────────────────────────────────────────────────────
SLIPPAGE_PIPS=0.5            # Simulated slippage on market entries
WALK_FORWARD_SPLIT=0.7       # In-sample fraction (0.7 = 70/30)
MIN_PROFIT_FACTOR=1.2        # Gate: min profit factor on out-of-sample
